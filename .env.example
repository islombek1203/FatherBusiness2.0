# Copy this file to .env (local dev) or provide these as real environment
# variables / secrets in production. Never commit an actual .env file.

# PostgreSQL connection string.
# Local dev matches the docker-compose "db" service credentials below.
DATABASE_URL="postgresql://inventory_app:CHANGE_ME@localhost:5432/inventory_db?schema=public"

# Auth.js (NextAuth) — generate with: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME"
# Set to "true" only if the app is served from a single, trusted host behind
# a reverse proxy (Caddy) that terminates TLS. Required for Docker/VPS deploys.
AUTH_TRUST_HOST="true"

NODE_ENV="production"

# --- Used by docker-compose.yml to provision the Postgres container ---
POSTGRES_USER="inventory_app"
POSTGRES_PASSWORD="CHANGE_ME"
POSTGRES_DB="inventory_db"

# Public domain Caddy will request a TLS certificate for (production only).
# Use "localhost" for local docker-compose testing.
DOMAIN="localhost"
