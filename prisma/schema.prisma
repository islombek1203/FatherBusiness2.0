// Prisma schema for the Cloud Inventory Management System.
// Connection URL is configured in prisma.config.ts (Prisma 7 convention), not here.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth & users (Phase 1)
// ---------------------------------------------------------------------------

// Admin: full access (users, settings, everything).
// Staff: record purchases/sales/adjustments, view dashboard and reports.
// Viewer: read-only access to dashboard and reports (no mutations).
enum Role {
  ADMIN
  STAFF
  VIEWER
}

// The two supported locales, per the localization spec (Uzbek Cyrillic default, Uzbek Latin).
enum Locale {
  UZ_CYRL
  UZ_LATN
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  locale       Locale   @default(UZ_CYRL)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions         Session[]
  accounts         Account[]
  inventoryHistory InventoryHistory[]
  purchases        Purchase[]
  sales            Sale[]
  expenses         Expense[]

  @@map("users")
}

// Auth.js Prisma adapter models (database session strategy = real server-side
// sessions, not JWT-in-cookie). Account/VerificationToken are part of the
// standard adapter schema; unused by the credentials-only flow today but kept
// so the adapter works unmodified and future OAuth providers can be added
// without a schema change.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Core inventory (Phase 2)
// ---------------------------------------------------------------------------

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Supplier {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchases Purchase[]

  @@map("suppliers")
}

// Fixed, non-extensible set — the UI never allows a custom color name.
// Each color of a product is its own Product row (own SKU, own stock, own
// history), not a shared "parent" with variant rows: that's what makes
// per-color stock/purchase/sale isolation automatic (every relation already
// scopes by productId) and makes "search by name" return every color for
// free (they all just share `name`).
enum ProductColor {
  OQ
  QORA
  SARIQ
}

// Дўкон (STORE) / Уй (HOME) — the two places stock is physically kept.
enum StockLocation {
  STORE
  HOME
}

model Product {
  id   String @id @default(cuid())
  sku  String @unique
  name String

  description String?
  color       ProductColor

  sellingPrice      Decimal  @db.Decimal(14, 2)
  // Cost of a product = the price on its most recent purchase (see
  // src/lib/costing.ts). Null until the first purchase is recorded (Phase 3).
  // Product-wide, not per-location — cost isn't a location concept.
  lastPurchasePrice Decimal? @db.Decimal(14, 2)
  // Denormalized running totals, kept in sync with InventoryHistory inside
  // the same DB transaction as every stock-touching mutation. Two columns
  // (not a join table) because the location set is fixed at two members —
  // every stock read is a plain column access, no extra join.
  storeStock        Int      @default(0)
  homeStock         Int      @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  history       InventoryHistory[]
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]

  @@index([categoryId])
  @@index([name])
  @@map("products")
}

// What kind of transaction moved stock. Purchases/Sales are recorded here
// too (Phase 3) so this table is the single append-only audit trail for
// every stock change, not just manual adjustments.
enum InventoryChangeType {
  PURCHASE
  SALE
  ADJUSTMENT
}

model InventoryHistory {
  id             String              @id @default(cuid())
  type           InventoryChangeType
  location       StockLocation
  // Before/after refer to `location`'s stock, not the product's combined total.
  quantityBefore Int
  quantityAfter  Int
  note           String?
  createdAt      DateTime            @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([createdAt])
  @@map("inventory_history")
}

// ---------------------------------------------------------------------------
// Transactions (Phase 3)
// ---------------------------------------------------------------------------

model Purchase {
  id          String   @id @default(cuid())
  note        String?
  // Denormalized sum of item quantity*unitCost, computed and stored inside
  // the same transaction that creates the items — a read-time convenience,
  // not a second source of truth.
  totalAmount Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  items PurchaseItem[]

  @@index([supplierId])
  @@index([createdAt])
  @@map("purchases")
}

model PurchaseItem {
  id       String        @id @default(cuid())
  quantity Int
  location StockLocation
  // Price paid per unit in this purchase. Recording a new PurchaseItem for a
  // product is what updates Product.lastPurchasePrice (see
  // src/lib/purchases.ts) — this is the raw input to the costing function.
  unitCost Decimal       @db.Decimal(14, 2)

  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

model Sale {
  id          String   @id @default(cuid())
  note        String?
  totalAmount Decimal  @db.Decimal(14, 2)
  totalProfit Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  items SaleItem[]

  @@index([createdAt])
  @@map("sales")
}

model SaleItem {
  id        String        @id @default(cuid())
  quantity  Int
  location  StockLocation
  unitPrice Decimal       @db.Decimal(14, 2)
  // Snapshot of getProductCost() (src/lib/costing.ts) at the moment of sale.
  // Historical profit must stay fixed to what it was at the time of the
  // sale, even if a later purchase changes the product's current cost.
  unitCost  Decimal       @db.Decimal(14, 2)

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

// ---------------------------------------------------------------------------
// Expenses
// ---------------------------------------------------------------------------

// Open-ended taxonomy (unlike ProductColor/StockLocation above, which are
// fixed, closed sets): new expense types are added by inserting a row here —
// no migration, no code change, matching how Category works for products.
// Seeded with the three required types (see prisma/seed.ts); more can be
// added later from the /expense-types UI without redesigning anything.
model ExpenseType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expenses Expense[]

  @@map("expense_types")
}

model Expense {
  id        String   @id @default(cuid())
  amount    Decimal  @db.Decimal(14, 2)
  note      String?
  createdAt DateTime @default(now())

  expenseTypeId String
  expenseType   ExpenseType @relation(fields: [expenseTypeId], references: [id], onDelete: Restrict)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([expenseTypeId])
  @@index([createdAt])
  @@map("expenses")
}
